{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=0"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=0"
        },
        {
          "key": "X-Vercel-Toolbar",
          "value": "false"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/dream-life-quiz",
      "dest": "/dream-life-quiz.html"
    }
  ]
}
